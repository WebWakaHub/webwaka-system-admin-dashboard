{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@webwaka/organelle-*": ["packages/organelles/*/src/index.ts"],
      "@webwaka/cell-*": ["packages/cells/*/src/index.ts"],
      "@webwaka/tissue-*": ["packages/tissues/*/src/index.ts"],
      "@webwaka/organ-*": ["packages/organs/*/src/index.ts"],
      "@webwaka/system-*": ["packages/systems/*/src/index.ts"],
      "@webwaka/organism-platform": ["packages/organism/platform/src/index.ts"],
      "@webwaka/organism-universe": ["packages/organism/universe/src/index.ts"],
      "@webwaka/shared-*": ["packages/shared/*/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
