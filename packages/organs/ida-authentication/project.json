{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "organ-ida-authentication",
  "sourceRoot": "packages/organs/ida-authentication/src",
  "projectType": "library",
  "tags": [
    "layer:organ",
    "domain:identity",
    "type:business"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/organs/ida-authentication",
        "tsConfig": "packages/organs/ida-authentication/tsconfig.json",
        "main": "packages/organs/ida-authentication/src/index.ts"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/organs/ida-authentication/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    }
  }
}
