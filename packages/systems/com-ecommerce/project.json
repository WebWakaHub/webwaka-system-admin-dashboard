{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "system-com-ecommerce",
  "sourceRoot": "packages/systems/com-ecommerce/src",
  "projectType": "library",
  "tags": [
    "layer:system",
    "domain:commerce",
    "type:platform"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/systems/com-ecommerce",
        "tsConfig": "packages/systems/com-ecommerce/tsconfig.json",
        "main": "packages/systems/com-ecommerce/src/index.ts"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/systems/com-ecommerce/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    }
  }
}
