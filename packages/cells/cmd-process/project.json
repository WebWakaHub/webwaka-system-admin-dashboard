{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "cell-cmd-process",
  "sourceRoot": "packages/cells/cmd-process/src",
  "projectType": "library",
  "tags": [
    "layer:cell",
    "type:capability"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/cells/cmd-process",
        "tsConfig": "packages/cells/cmd-process/tsconfig.json",
        "main": "packages/cells/cmd-process/src/index.ts"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/cells/cmd-process/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    }
  }
}
