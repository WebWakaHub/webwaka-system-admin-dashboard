{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "organelle-resource-allocator",
  "sourceRoot": "packages/organelles/resource-allocator/src",
  "projectType": "library",
  "tags": [
    "layer:organelle",
    "scope:resource-allocator",
    "type:primitive"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/organelles/resource-allocator",
        "tsConfig": "packages/organelles/resource-allocator/tsconfig.json",
        "main": "packages/organelles/resource-allocator/src/index.ts"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "packages/organelles/resource-allocator/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    }
  }
}
